{
  "expo": {
    "name": "Cato",
    "slug": "cato",
    "version": "0.0.0",
    "scheme": "cato",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.catoai.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Cato needs the microphone for voice commands.",
        "NSLocalNetworkUsageDescription": "Cato discovers your desktop agents on the local network.",
        "NSBonjourServices": ["_cato._tcp"]
      }
    },
    "android": {
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.CHANGE_WIFI_MULTICAST_STATE",
        "android.permission.INTERNET"
      ]
    },
    "extra": {
      "//": "Set your desktop agent address + pairing token here (or via the in-app field).",
      "desktopWsUrl": "ws://192.168.68.102:8787/v1",
      "pairingToken": "changeme"
    },
    "plugins": [
      "expo-audio",
      "expo-status-bar"
    ]
  }
}
