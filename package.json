{
  "name": "cato",
  "version": "0.0.0",
  "private": true,
  "description": "Cato — voice-first operating system for AI coding agents",
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/desktop-agent"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node packages/desktop-agent/dist/index.js",
    "setup": "./install.sh",
    "daemon:on": "./bin/cato-daemon.sh on",
    "daemon:off": "./bin/cato-daemon.sh off",
    "build": "npm run build -w @cato/shared && npm run build -w @cato/desktop-agent",
    "test": "node --import tsx --test packages/desktop-agent/test/*.test.ts",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:agent": "npm run dev -w @cato/desktop-agent",
    "db:up": "docker compose -f infra/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker-compose.yml down",
    "db:schema": "docker compose -f infra/docker-compose.yml exec -T db psql -U cato -d cato -f /docker-entrypoint-initdb.d/schema.sql"
  }
}
