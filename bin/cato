#!/usr/bin/env bash
# cato — launch a coding agent inside a tmux session that Cato auto-discovers and
# captures. Run your agent via `cato` instead of directly and it always lands in a
# pane Cato is watching. Supports claude-cli and codex-cli out of the box.
#
#   cato                 # launches the default agent (claude, else codex)
#   cato codex           # launch codex
#   cato claude --resume <id>
#
# Session is `cato-<project>`; re-running attaches to it (one agent per project).
# Detach with Ctrl-b d and walk away — Cato keeps capturing.
set -euo pipefail

self="$0"; [ -L "$self" ] && self="$(readlink "$self")"
selfdir="$(cd "$(dirname "$self")" && pwd)"

case "${1:-}" in
  help|-h|--help)
    cat <<'USAGE'
cato — voice-first command center for AI coding agents

Usage:
  cato                 launch your agent (claude, else codex) in this folder, watched by Cato
  cato claude|codex …  launch a specific agent (extra args are passed through)
  cato setup           onboard this machine: pick a workspace + get a pairing token & QR
  cato pair            show the QR / token again to add another device
  cato rotate          generate a NEW token (disconnects all paired devices) + show QR
  cato doctor          diagnose the local setup (deps, models, onboarding, security)
  cato help            show this help

Run the brain:  npm start   ·   always-on:  npm run daemon:on / daemon:off
USAGE
    exit 0 ;;
esac
# `cato setup` → onboarding (workspace root + pairing token).
if [ "${1:-}" = "setup" ]; then exec node "$selfdir/cato-setup.mjs"; fi
# `cato pair` → show the QR/token to add another device.
if [ "${1:-}" = "pair" ]; then exec node "$selfdir/cato-pair.mjs"; fi
# `cato rotate` → new token (disconnects old devices).
if [ "${1:-}" = "rotate" ]; then exec node "$selfdir/cato-rotate.mjs"; fi
# `cato doctor` → diagnose the local setup.
if [ "${1:-}" = "doctor" ]; then exec node "$selfdir/cato-doctor.mjs"; fi

# First run on this machine: no config yet → onboard before launching.
if [ ! -f "$HOME/.cato/config.json" ]; then
  echo "cato: first run on this machine — let's set up." >&2
  node "$selfdir/cato-setup.mjs"
fi

# Pick the agent: explicit first arg, else the first installed of claude / codex.
if [ "$#" -gt 0 ] && command -v "$1" >/dev/null 2>&1; then
  agent="$1"; shift
elif command -v claude >/dev/null 2>&1; then agent="claude"
elif command -v codex  >/dev/null 2>&1; then agent="codex"
else
  echo "cato: no coding agent found. Install one:" >&2
  echo "  claude:  https://docs.claude.com/claude-code" >&2
  echo "  codex:   npm i -g @openai/codex" >&2
  exit 1
fi

# Install Cato's approval hook into THIS project (Claude only; project-scoped, so it
# never gates your global claude or other sessions).
if [ "$agent" = "claude" ]; then
  node "$selfdir/cato-install-hook.mjs" "$PWD" "${CATO_WS_PORT:-8787}" 2>/dev/null || true
fi

# Already inside tmux: just run it (your current session is what Cato sees).
if [ -n "${TMUX:-}" ]; then exec "$agent" "$@"; fi

proj="cato-$(basename "$PWD" | tr -c 'A-Za-z0-9_-' '_')"
exec tmux new-session -A -s "$proj" "$agent" "$@"
