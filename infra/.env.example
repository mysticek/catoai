# Copy to .env and adjust. Used by the desktop-agent.
# Embedded database (PGlite) — a directory, no Docker/Postgres server. Cross-platform.
DB_DIR=~/.cato/db

# WebSocket server (mobile <-> desktop-agent)
WS_HOST=0.0.0.0
WS_PORT=8787
# shared pairing token the mobile client must present in `hello`
PAIRING_TOKEN=changeme

# local embeddings via Ollama. bge-m3 is multilingual (incl. Slovak), 1024-dim.
# EMBEDDING_DIM must match infra/db/schema.sql VECTOR(n).
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024

# local speech-to-text (whisper.cpp). STT_MODEL must point at a ggml model file.
# brew install whisper-cpp; large-v3-turbo = best accuracy/speed for multilingual.
STT_BIN=whisper-cli
STT_MODEL=~/.cato/models/ggml-large-v3-turbo.bin
# warm whisper.cpp server (model stays loaded → ~1s STT). The agent auto-starts it.
STT_SERVER_URL=http://127.0.0.1:8088

# local LLM for summaries + intent classification via Ollama. gemma3:4b is
# non-reasoning + multilingual (clean output); avoid reasoning models (qwen3) — they
# leak their thinking into prose.
LLM_MODEL=gemma3:4b
