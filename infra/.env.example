# Copy to .env and adjust. Used by the desktop-agent.
DATABASE_URL=postgres://cato:cato@localhost:5433/cato

# WebSocket server (mobile <-> desktop-agent)
WS_HOST=0.0.0.0
WS_PORT=8787
# shared pairing token the mobile client must present in `hello`
PAIRING_TOKEN=changeme

# embedding model dimension must match infra/db/schema.sql VECTOR(n)
EMBEDDING_DIM=768

# local speech-to-text (whisper.cpp). STT_MODEL must point at a ggml model file.
# brew install whisper-cpp; download e.g. ggml-base.bin / ggml-small.bin
STT_BIN=whisper-cli
STT_MODEL=~/.cato/models/ggml-base.bin
